{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CogShift",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Generate Gear Model",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/generate_gear.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "console": "integratedTerminal"
    }
  ]
}
